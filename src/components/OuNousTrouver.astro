---
import { SITE_CONFIG, MARKETS } from '@/lib/constants';
---

<section id="trouver" class="bg-secondary py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="scroll-reveal mb-16 text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-primary">Venez nous voir</p>
      <h2 class="mt-3 font-serif text-4xl font-bold text-foreground">Où nous trouver</h2>
    </div>

    <div class="scroll-reveal grid gap-8 md:grid-cols-2">
      <!-- Marchés -->
      <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
        <div class="mb-6 flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.15c0 .415.336.75.75.75z" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-foreground">Sur les marchés</h3>
        </div>
        <div class="space-y-4">
          {MARKETS.map((market) => (
            <div class="rounded-xl bg-secondary p-4">
              <p class="font-semibold text-foreground">{market.name}</p>
              <p class="mt-1 text-sm text-muted">{market.schedule}</p>
              <p class="text-sm text-muted">{market.location}</p>
            </div>
          ))}
          <p class="text-sm text-muted/70 italic">
            D'autres marchés selon la saison — appelez-nous pour connaître notre prochain passage !
          </p>
        </div>
      </div>

      <!-- Vente directe -->
      <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
        <div class="mb-6 flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-accent/10">
            <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-foreground">Vente directe</h3>
        </div>
        <p class="text-muted leading-relaxed">
          Passez nous voir directement ! Nous vous accueillons sur rendez-vous pour vous faire découvrir nos miels et gourmandises.
        </p>
        <div class="mt-6 space-y-3">
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <p class="text-sm text-foreground">
              {SITE_CONFIG.address}<br />
              {SITE_CONFIG.city}
            </p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a
              href={`tel:${SITE_CONFIG.phone.replace(/\s/g, '')}`}
              class="text-sm font-semibold text-primary hover:underline"
            >
              {SITE_CONFIG.phone}
            </a>
          </div>
        </div>
        <a
          href={`tel:${SITE_CONFIG.phone.replace(/\s/g, '')}`}
          class="mt-8 block rounded-full bg-primary px-6 py-3 text-center text-sm font-semibold text-white transition-colors hover:bg-primary/90"
        >
          Appelez-nous
        </a>
      </div>
    </div>

    <!-- Carte -->
    <div class="scroll-reveal mt-8">
      <div class="overflow-hidden rounded-2xl border border-border shadow-sm">
        <iframe
          src="https://www.google.com/maps?q=3+place+de+l%27%C3%89glise,+02330+Cond%C3%A9-en-Brie,+France&output=embed"
          width="100%"
          height="350"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Le Rucher de la Gravière — 3 place de l'Église, Condé-en-Brie"
        ></iframe>
      </div>
    </div>
  </div>
</section>
