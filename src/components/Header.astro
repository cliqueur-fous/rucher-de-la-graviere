---
import { NAV_LINKS, SITE_CONFIG } from '@/lib/constants';
---

<header id="header" class="fixed z-50 w-full transition-all duration-300" style="top: 0;">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="font-serif text-xl font-bold text-foreground transition-colors hover:text-primary">
      {SITE_CONFIG.name}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 md:flex">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-muted transition-colors hover:text-primary"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`tel:${SITE_CONFIG.phone.replace(/\s/g, '')}`}
        class="rounded-full bg-primary px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary/90"
      >
        {SITE_CONFIG.phone}
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-toggle"
      class="flex flex-col gap-1.5 md:hidden"
      aria-label="Ouvrir le menu"
    >
      <span class="block h-0.5 w-6 bg-foreground transition-all duration-300" id="bar1"></span>
      <span class="block h-0.5 w-6 bg-foreground transition-all duration-300" id="bar2"></span>
      <span class="block h-0.5 w-6 bg-foreground transition-all duration-300" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border bg-background/95 backdrop-blur-md md:hidden">
    <nav class="mx-auto flex max-w-6xl flex-col px-4 py-4">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class="mobile-link py-3 text-base font-medium text-foreground transition-colors hover:text-primary"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`tel:${SITE_CONFIG.phone.replace(/\s/g, '')}`}
        class="mt-3 rounded-full bg-primary px-4 py-2.5 text-center text-sm font-semibold text-white"
      >
        Appeler : {SITE_CONFIG.phone}
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('header')!;
  const banner = document.getElementById('market-banner');
  const toggle = document.getElementById('mobile-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;
  let open = false;

  // Position header below banner + solid background on scroll
  const updateHeader = () => {
    const bannerH = banner ? banner.offsetHeight : 0;
    const scrolled = window.scrollY > bannerH;
    header.style.top = scrolled ? '0px' : `${bannerH}px`;
    if (scrolled || open) {
      header.classList.add('bg-background/95', 'backdrop-blur-md', 'shadow-sm');
    } else {
      header.classList.remove('bg-background/95', 'backdrop-blur-md', 'shadow-sm');
    }
  };

  window.addEventListener('scroll', updateHeader, { passive: true });
  window.addEventListener('resize', updateHeader, { passive: true });
  updateHeader();

  // Mobile toggle
  toggle.addEventListener('click', () => {
    open = !open;
    menu.classList.toggle('hidden');
    bar1.style.transform = open ? 'rotate(45deg) translate(4px, 4px)' : '';
    bar2.style.opacity = open ? '0' : '1';
    bar3.style.transform = open ? 'rotate(-45deg) translate(4px, -4px)' : '';
    updateHeader();
  });

  // Close menu on link click
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      open = false;
      menu.classList.add('hidden');
      bar1.style.transform = '';
      bar2.style.opacity = '1';
      bar3.style.transform = '';
      updateHeader();
    });
  });
</script>
