---
import { HISTOIRE } from '@/lib/constants';
---

<section id="histoire" class="py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Text -->
      <div class="scroll-reveal">
        <p class="text-sm font-medium uppercase tracking-widest text-primary">Depuis des années</p>
        <h2 class="mt-3 font-serif text-4xl font-bold text-foreground">{HISTOIRE.title}</h2>
        <div class="mt-6 space-y-4">
          {HISTOIRE.paragraphs.map((p) => (
            <p class="text-muted leading-relaxed">{p}</p>
          ))}
        </div>
      </div>

      <!-- Image -->
      <div class="scroll-reveal">
        <div class="overflow-hidden rounded-2xl shadow-xl">
          <img
            src="/images/hero-rucher.jpg"
            alt="Apiculteurs au travail dans la verdure"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
