---
import { PRODUCTS } from '@/lib/constants';
---

<section id="produits" class="bg-secondary py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="scroll-reveal mb-16 text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-primary">Du rucher à votre table</p>
      <h2 class="mt-3 font-serif text-4xl font-bold text-foreground">Nos produits</h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted">
        Tous nos miels sont récoltés et mis en pot artisanalement. Nos gourmandises sont préparées avec notre propre miel.
      </p>
    </div>

    <div class="scroll-reveal grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {PRODUCTS.map((product, i) => (
        <div class={`stagger-item overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-shadow hover:shadow-md`}>
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={product.image}
              alt={product.name}
              class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-serif text-lg font-bold text-foreground">{product.name}</h3>
              <span class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ${
                product.category === 'miel'
                  ? 'bg-primary/10 text-primary'
                  : 'bg-accent/10 text-accent'
              }`}>
                {product.category === 'miel' ? 'Miel' : 'Gourmandise'}
              </span>
            </div>
            <p class="mt-2 text-sm text-muted">{product.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {product.prices.map((p) => (
                <span class="rounded-lg bg-secondary px-3 py-1.5 text-sm font-semibold text-foreground">
                  {p.size} — {p.price}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
