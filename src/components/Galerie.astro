---
import { GALLERY_IMAGES } from '@/lib/constants';
---

<section id="galerie" class="py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="scroll-reveal mb-16 text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-primary">En images</p>
      <h2 class="mt-3 font-serif text-4xl font-bold text-foreground">Galerie</h2>
    </div>

    <div class="scroll-reveal grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {GALLERY_IMAGES.map((img, i) => (
        <div class={`stagger-item overflow-hidden rounded-xl shadow-sm ${
          i === 0 ? 'sm:col-span-2 sm:row-span-2' : ''
        }`}>
          <img
            src={img.src}
            alt={img.alt}
            class="h-full w-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
