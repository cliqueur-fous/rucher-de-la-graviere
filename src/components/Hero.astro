---
import { SITE_CONFIG } from '@/lib/constants';
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/apiculteur-solo.jpg"
      alt="Apiculteur au travail"
      class="h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-foreground/60 via-foreground/50 to-foreground/70" />
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-4xl px-4 text-center">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-primary-light">
      Apiculteurs à Condé-en-Brie
    </p>

    <h1 class="mt-4 font-serif text-5xl font-bold leading-tight text-white sm:text-6xl lg:text-7xl">
      {SITE_CONFIG.name}
    </h1>

    <p class="mt-6 text-lg text-white/80 sm:text-xl">
      Récolté avec passion, au cœur de l'Aisne
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="#produits"
        class="rounded-full bg-primary px-8 py-3.5 text-sm font-semibold text-white shadow-lg transition-all hover:bg-primary/90 hover:shadow-xl"
      >
        Découvrir nos produits
      </a>
      <a
        href="#trouver"
        class="rounded-full border-2 border-white/40 px-8 py-3.5 text-sm font-semibold text-white transition-all hover:border-white hover:bg-white/10"
      >
        Nous trouver
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-6 w-6 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
