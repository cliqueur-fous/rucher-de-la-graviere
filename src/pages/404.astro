---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page introuvable">
  <section class="flex min-h-[60vh] items-center justify-center px-4">
    <div class="text-center">
      <p class="text-6xl font-bold text-primary">404</p>
      <h1 class="mt-4 font-serif text-3xl font-bold text-foreground">Page introuvable</h1>
      <p class="mt-4 text-muted">Cette page n'existe pas ou a été déplacée.</p>
      <a
        href="/"
        class="mt-8 inline-block rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-primary/90"
      >
        Retour à l'accueil
      </a>
    </div>
  </section>
</BaseLayout>
